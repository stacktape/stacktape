{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@generated/*": ["../@generated/*"]
    },
    "strict": false
  },
  "include": [".astro/types.d.ts", "**/*.ts", "**/*.tsx", "**/*.astro", "globals.d.ts"],
  "exclude": ["node_modules", "out", "dist"]
}
