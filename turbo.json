{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["pnpm-workspace.yaml", "tsconfig.base.json", "tsconfig.package.json"],
  "tasks": {
    "generate": {
      "description": "Generate derived source and metadata from canonical inputs",
      "outputs": ["generated/**"]
    },
    "generate:check": {
      "description": "Verify committed generated artifacts are current",
      "cache": false
    },
    "build": {
      "description": "Build a workspace after its dependencies and generators",
      "dependsOn": ["^build", "^generate", "generate"],
      "outputs": ["dist/**", ".astro/**", "!.astro/cache/**"]
    },
    "typecheck": {
      "description": "Type-check source against generated artifacts",
      "dependsOn": ["^generate", "generate"],
      "outputs": []
    },
    "test": {
      "description": "Run deterministic behavioral tests",
      "dependsOn": ["generate", "^generate", "^build"],
      "outputs": []
    },
    "dev": {
      "description": "Run a workspace development process",
      "cache": false,
      "persistent": true
    }
  }
}
