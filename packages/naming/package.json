{
  "name": "@stacktape/naming",
  "version": "4.0.0-dev.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./arns": "./src/arns.ts",
    "./case": "./src/case.ts",
    "./cloudformation-registry": "./src/cloudformation-registry-names.ts",
    "./cloudfront-headers": "./src/cloudfront-header-names.ts",
    "./domain": "./src/domain-names.ts",
    "./helper-lambdas": "./src/helper-lambdas-resource-names.ts",
    "./logical": "./src/logical-names.ts",
    "./metadata": "./src/metadata-names.ts",
    "./names": "./src/names.ts",
    "./outputs": "./src/stack-output-names.ts",
    "./physical": "./src/aws-resource-names.ts",
    "./referenceable-parameters": "./src/referenceable-parameter-names.ts",
    "./ssm": "./src/ssm-parameter-names.ts",
    "./tags": "./src/tag-names.ts"
  },
  "scripts": {
    "fixtures:check": "node --import=tsx test/generate-fixtures.ts --check",
    "fixtures:generate": "node --import=tsx test/generate-fixtures.ts --write",
    "test": "pnpm fixtures:check && node --import=tsx --test test/*.test.ts && pnpm test:legacy",
    "test:legacy": "node --import=tsx test/compare-legacy.ts",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "change-case": "5.4.4",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
